# ===========================================
# Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in real values.
# All variables are validated by Zod at startup (src/lib/env.ts).
# Production values live in `vercel env` — never commit .env.local.
# ===========================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App (required) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Template-Projects

# --- Analytics (optional) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=

# --- Payments (optional) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Product IDs — copy from Stripe Dashboard → Products
STRIPE_PRODUCT_ID_PRO=
STRIPE_PRODUCT_ID_TEAM=
# Price IDs — copy from the product's pricing tab
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_TEAM=

# --- AI (optional) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Email (optional) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@example.com

# --- Cron jobs (set when wiring scheduled routes; min 16 chars) ---
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Rate limiting (optional — falls back to in-memory) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Error tracking (optional) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Product analytics — PostHog (optional) ---
# Get your key at https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Feature flags (optional) ---
# Flip to "true" or "1" to enable each section without redeploy.
NEXT_PUBLIC_FF_BILLING=false
NEXT_PUBLIC_FF_AI=false
NEXT_PUBLIC_FF_ANALYTICS=false
NEXT_PUBLIC_FF_ONBOARDING=false
NEXT_PUBLIC_FF_NOTIFICATIONS=false
NEXT_PUBLIC_FF_API_KEYS=false
